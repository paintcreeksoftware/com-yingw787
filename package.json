{
  "name": "tailwind-plus-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check": "tsc --noEmit && eslint . && prettier . --check",
    "fix": "eslint . --fix && prettier . --write",
    "check-bundle-size": "bundlewatch",
    "check-dead-links": "linkinator ./out --recurse --skip-external --verbosity error"
  },
  "bundlewatch": {
    "files": [
      {
        "path": ".next/static/chunks/*.js",
        "maxSize": "265kB"
      },
      {
        "path": ".next/static/chunks/*.css",
        "maxSize": "31kB"
      }
    ]
  },
  "browserslist": "defaults, not ie <= 11",
  "dependencies": {
    "@headlessui/react": "^2.2.6",
    "@heroicons/react": "^2.2.0",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/webpack-env": "^1.18.8",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.1",
    "fast-glob": "^3.3.3",
    "feed": "^5.1.0",
    "heroicons": "^2.2.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "bundlewatch": "^0.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "linkinator": "^7.6.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "0.34.3"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
